[0m22:18:48.298057 [debug] [Thread-3 (]: On model.incremental_sales_etl_dbt.sales_summary: /* {"app": "dbt", "dbt_version": "1.12.0b1", "profile_name": "incremental_sales_etl_dbt", "target_name": "dev", "node_id": "model.incremental_sales_etl_dbt.sales_summary"} */

  create view "sales_warehouse"."analytics"."sales_summary__dbt_tmp"
    
    
  as (
    WITH sales AS (

    SELECT *
    FROM "sales_warehouse"."analytics_staging"."stg_sales"

),

aggregated AS (

    SELECT
        order_date,
        product_id,

        COUNT(order_id) AS total_orders,

        SUM(quantity) AS total_quantity,

        SUM(total_amount) AS total_revenue,

        AVG(total_amount) AS avg_order_value

    FROM sales
    GROUP BY 1, 2

)

SELECT *
FROM aggregated
  );
